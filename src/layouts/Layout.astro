---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Free Singapore salary calculator for 2026. Calculate your take-home pay after CPF contributions and income tax. Covers Citizens, PRs, and Foreigners.', canonical } = Astro.props;
const siteUrl = 'https://salarycalculator.sg';
const pageUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mottalib Radif" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="en_SG" />
    <meta property="og:site_name" content="SalaryCalculator.sg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Schema.org WebApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Singapore Salary Calculator 2026",
      "url": siteUrl,
      "description": description,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "SGD"
      },
      "author": {
        "@type": "Organization",
        "name": "SalaryCalculator.sg"
      }
    })} />

    <!-- Schema.org FAQPage (for homepage) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much CPF do I contribute in Singapore?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For Singapore Citizens and PRs (3rd year+) aged 55 and below, the employee contributes 20% and the employer contributes 17% of ordinary wages, for a total of 37%. Rates decrease with age."
          }
        },
        {
          "@type": "Question",
          "name": "What is the CPF Ordinary Wage ceiling?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The CPF Ordinary Wage (OW) ceiling is $6,800 per month. CPF contributions are calculated on the lower of actual wages or this ceiling."
          }
        },
        {
          "@type": "Question",
          "name": "Do foreigners pay CPF in Singapore?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, foreigners (Employment Pass, S Pass holders) do not contribute to CPF. Only Singapore Citizens and Permanent Residents are required to make CPF contributions."
          }
        }
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Mottalib Radif",
      "jobTitle": "Personal Finance & Taxation Expert",
      "description": "MBA INSEAD graduate, passionate about Singapore personal finance. Specialised in CPF contributions, income tax, and salary optimisation.",
      "alumniOf": { "@type": "EducationalOrganization", "name": "INSEAD" },
      "image": "https://salarycalculator.sg/team/mottalib-radif.jpg",
      "url": "https://salarycalculator.sg/about/"
    })} />

    <!-- Plausible Analytics -->
    <script defer data-domain="salarycalculator.sg" src="https://plausible.io/js/script.js"></script>

    <!-- TODO: Replace G-XXXXXXXXXX with your real GA4 Measurement ID from https://analytics.google.com -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-blue-700 focus:rounded-lg focus:shadow-lg focus:ring-2 focus:ring-blue-500">Skip to content</a>
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-xl font-black text-primary hover:text-primary-dark transition-colors">
          <svg width="28" height="28" viewBox="0 0 100 100" class="shrink-0">
            <rect width="100" height="100" rx="16" fill="#dc2626"/>
            <text x="50" y="38" text-anchor="middle" font-size="22" font-weight="900" fill="white" font-family="system-ui">SG</text>
            <text x="50" y="72" text-anchor="middle" font-size="32" font-weight="900" fill="white" font-family="system-ui">$</text>
          </svg>
          SalaryCalculator.sg
        </a>
        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/" class="hover:text-primary transition-colors">Calculator</a>
          <a href="/guides/" class="hover:text-primary transition-colors">Guides</a>
          <a href="/faq/" class="hover:text-primary transition-colors">FAQ</a>
          <a href="/legal/" class="hover:text-primary transition-colors">Legal</a>
        </div>
        <!-- Mobile Hamburger Button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden relative w-8 h-8 flex flex-col items-center justify-center gap-1.5"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="mobile-menu-line block w-6 h-0.5 bg-gray-700 transition-all duration-300 ease-in-out origin-center"></span>
          <span class="mobile-menu-line block w-6 h-0.5 bg-gray-700 transition-all duration-300 ease-in-out origin-center"></span>
          <span class="mobile-menu-line block w-6 h-0.5 bg-gray-700 transition-all duration-300 ease-in-out origin-center"></span>
        </button>
      </nav>
      <!-- Mobile Navigation Panel -->
      <div
        id="mobile-menu"
        class="md:hidden hidden border-t border-gray-200 bg-white"
      >
        <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-3 text-sm font-medium text-gray-600">
          <a href="/" class="hover:text-primary transition-colors py-2">Calculator</a>
          <a href="/guides/" class="hover:text-primary transition-colors py-2">Guides</a>
          <a href="/faq/" class="hover:text-primary transition-colors py-2">FAQ</a>
          <a href="/legal/" class="hover:text-primary transition-colors py-2">Legal</a>
          <a href="/privacy/" class="hover:text-primary transition-colors py-2">Privacy</a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-bold text-lg mb-3">SalaryCalculator.sg</h3>
            <p class="text-sm leading-relaxed">
              Free Singapore salary calculator. Compute your take-home pay after CPF contributions and income tax for YA2026.
            </p>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3">Resources</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-white transition-colors">Salary Calculator</a></li>
              <li><a href="/guides/" class="hover:text-white transition-colors">Guides</a></li>
              <li><a href="/faq/" class="hover:text-white transition-colors">FAQ</a></li>
              <li><a href="https://www.cpf.gov.sg" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">CPF Board</a></li>
              <li><a href="https://www.iras.gov.sg" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">IRAS</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3">Legal</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/legal/" class="hover:text-white transition-colors">Disclaimer</a></li>
              <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-xs">
          <p>&copy; {new Date().getFullYear()} SalaryCalculator.sg. Not affiliated with CPF Board, IRAS, or the Singapore Government.</p>
          <p class="mt-1">For illustrative purposes only. Always verify with official sources.</p>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Toggle Script -->
    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;
        btn.addEventListener('click', function() {
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          menu.classList.toggle('hidden');
          var lines = btn.querySelectorAll('.mobile-menu-line');
          if (!expanded) {
            lines[0].style.transform = 'translateY(4px) rotate(45deg)';
            lines[1].style.opacity = '0';
            lines[2].style.transform = 'translateY(-4px) rotate(-45deg)';
          } else {
            lines[0].style.transform = '';
            lines[1].style.opacity = '';
            lines[2].style.transform = '';
          }
        });
      })();
    </script>
  </body>
</html>
