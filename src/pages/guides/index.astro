---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const guides = [
  {
    slug: 'cpf-contribution-rates',
    icon: '📊',
    title: 'CPF Contribution Rates 2026',
    description: 'Complete guide to CPF rates by age group, wage ceilings, and employer/employee contribution breakdowns for 2026.',
  },
  {
    slug: 'cpf-for-foreigners',
    icon: '🌏',
    title: 'CPF for Foreigners',
    description: 'What Employment Pass and S Pass holders need to know about CPF exemptions, levies, and take-home pay.',
  },
  {
    slug: 'singapore-income-tax',
    icon: '🧾',
    title: 'Singapore Income Tax 2026',
    description: 'Progressive tax rates, reliefs, rebates, and filing deadlines for Year of Assessment 2026.',
  },
  {
    slug: 'ep-vs-pr-salary',
    icon: '⚖️',
    title: 'Employment Pass vs PR Salary',
    description: 'Net pay comparison between EP holders and PRs - who takes home more and why.',
  },
  {
    slug: 'cpf-oa-sa-ma-explained',
    icon: '🏦',
    title: 'CPF OA, SA, MA Explained',
    description: 'How your CPF contributions are split across Ordinary, Special, and MediSave accounts by age.',
  },
  {
    slug: 'tax-residency-183-days',
    icon: '📅',
    title: 'Tax Residency & the 183-Day Rule',
    description: 'Understanding Singapore tax residency, the 183-day rule, and non-resident tax rates.',
  },
  {
    slug: 'bonus-aws-tax',
    icon: '🎁',
    title: 'Bonus & AWS Tax Treatment',
    description: 'How your 13th-month salary, performance bonuses, and variable pay are taxed and subject to CPF.',
  },
  {
    slug: 'salary-negotiation-singapore',
    icon: '💼',
    title: 'Salary Negotiation in Singapore',
    description: 'Market rates, total compensation benchmarks, and negotiation strategies for the Singapore job market.',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://salarycalculator.sg/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Guides",
      "item": "https://salarycalculator.sg/guides/"
    }
  ]
};
---

<Layout title="Salary Guides - Singapore CPF, Tax & Compensation | SalaryCalculator.sg" description="In-depth guides on Singapore CPF contributions, income tax rates, salary negotiation, and take-home pay comparisons for citizens, PRs, and foreigners.">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-8 text-sm text-gray-500">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li class="before:content-['/'] before:mr-2 text-gray-900 font-medium">Guides</li>
    </ol>
  </nav>

  <section class="mb-12">
    <h1 class="text-4xl font-black text-gray-900 mb-4">Singapore Salary Guides</h1>
    <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">
      Everything you need to understand your Singapore salary. From CPF contribution rates and income tax brackets to salary negotiation strategies - practical, detailed guides updated for 2026.
    </p>
  </section>

  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-16">
    {guides.map((guide) => (
      <a
        href={`/guides/${guide.slug}/`}
        class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md hover:border-primary/30 transition-all duration-200 flex flex-col"
      >
        <span class="text-3xl mb-4 block">{guide.icon}</span>
        <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary transition-colors">{guide.title}</h2>
        <p class="text-sm text-gray-600 leading-relaxed mb-4 flex-grow">{guide.description}</p>
        <span class="text-sm font-semibold text-primary group-hover:underline">Read guide &rarr;</span>
      </a>
    ))}
  </section>
</Layout>
