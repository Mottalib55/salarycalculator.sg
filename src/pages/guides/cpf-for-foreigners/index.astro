    {
      "@type": "Question",
      "name": "Can a foreigner voluntarily contribute to CPF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. CPF membership is only available to Singapore Citizens and Permanent Residents. Foreigners cannot make voluntary contributions to CPF, even if they wish to do so."
