  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the highest income tax rate in Singapore for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The highest marginal income tax rate in Singapore for Year of Assessment 2026 is 24%, which applies to chargeable income exceeding $1,000,000. The previous top band of 23% applies to income between $500,001 and $1,000,000."
      }
    },
    {
      "@type": "Question",
      "name": "When is the income tax filing deadline in Singapore?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For paper filing, the deadline is 15 April. For e-filing via myTax Portal, the deadline is 18 April. These dates apply to the Year of Assessment for income earned in the preceding calendar year."
      }
