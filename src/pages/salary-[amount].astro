---
import Layout from '../layouts/Layout.astro';
import SalaryCalculator from '../components/SalaryCalculator';
import { SALARY_LEVELS, type SalaryEntry } from '../lib/salaries-data';
import { AGE_BRACKETS, type AgeBracketEntry } from '../lib/age-brackets-data';
import { calculateSalary } from '../lib/engine';
import { generateSalaryPageContent } from '../lib/salary-content';
import '../styles/global.css';

export function getStaticPaths() {
  return SALARY_LEVELS.map((s) => ({
    params: { amount: s.slug },
    props: { salary: s },
  }));
}

interface Props {
  salary: SalaryEntry;
}

const { salary } = Astro.props;
const siteUrl = 'https://salarycalculator.sg';

// Generate all unique content for this salary level
const content = generateSalaryPageContent(salary.gross);

// Calculate net pay for age brackets comparison table
const ageBracketRows = [
  { label: '55 and below', age: 30 },
  { label: '55 to 60', age: 58 },
  { label: '60 to 65', age: 63 },
  { label: 'Above 65', age: 68 },
].map((bracket) => {
  const result = calculateSalary({
    monthlyGross: salary.gross,
    age: bracket.age,
    residencyType: 'citizen',
    annualBonus: 0,
  });
  return {
    label: bracket.label,
    gross: salary.grossFormatted,
    cpfEmployee: `S$${result.monthlyEmployeeCPF.toLocaleString('en-SG')}`,
    cpfEmployeeRate: result.cpfRate ? `${result.cpfRate.employee}%` : '0%',
    cpfEmployer: `S$${result.cpf.employerContribution.toLocaleString('en-SG')}`,
    net: `S$${result.monthlyTakeHome.toLocaleString('en-SG')}`,
    monthlyTax: `S$${result.monthlyTax.toLocaleString('en-SG')}`,
  };
});

// Main stats (age 30 citizen)
const mainResult = calculateSalary({
  monthlyGross: salary.gross,
  age: 30,
  residencyType: 'citizen',
  annualBonus: 0,
});

function formatSGD(n: number): string {
  return `S$${n.toLocaleString('en-SG')}`;
}

const pageTitle = `${salary.grossFormatted} Salary in Singapore - Take Home Pay Calculator 2026`;
const pageDescription = `Calculate your take-home pay on a ${salary.grossFormatted} monthly salary in Singapore. See CPF contributions, income tax, and net pay by age bracket for 2026.`;

// Unique intro text per salary level
const introTexts: Record<number, string> = {
  3000: `On an entry-level income of ${salary.grossFormatted} per month in Singapore, understanding your exact deductions matters for budgeting. Below you will find the complete picture: CPF withholding, IRAS income tax, and what actually lands in your bank account.`,
  4000: `Earning ${salary.grossFormatted} monthly as a graduate or early-career professional in Singapore? This page shows precisely how much you keep after CPF contributions and income tax are accounted for, with breakdowns by age group.`,
  5000: `At the Singapore median income level of ${salary.grossFormatted} per month, your deductions and net pay represent the typical working professional's experience. Explore the exact numbers for CPF, tax, and take-home below.`,
  6000: `With ${salary.grossFormatted} monthly earnings sitting just below the CPF wage ceiling, your salary attracts near-maximum CPF contributions. See the precise impact on your take-home pay and how it varies across age brackets.`,
  7000: `Your ${salary.grossFormatted} salary crosses above Singapore's CPF ceiling of S$6,800, creating an interesting dynamic where part of your pay avoids CPF deduction. Discover exactly how this affects your net income.`,
  8000: `Professionals earning ${salary.grossFormatted} per month enjoy the benefit of the CPF ceiling effect — only a portion of salary attracts mandatory savings. Below is the detailed breakdown of deductions and net pay.`,
  10000: `A five-figure monthly salary of ${salary.grossFormatted} in Singapore comes with ceiling-capped CPF and progressive taxation. This page calculates your exact after-tax, after-CPF income with precision.`,
  12000: `At ${salary.grossFormatted} per month, you are well into upper-quartile territory in Singapore. The numbers below reveal how CPF capping and progressive tax brackets shape your actual take-home compensation.`,
  15000: `Senior professionals commanding ${salary.grossFormatted} monthly benefit from Singapore's competitive tax regime. Here is the precise calculation of your net income after all statutory deductions and levies.`,
  20000: `Executive compensation of ${salary.grossFormatted} per month attracts Singapore's higher tax brackets while CPF remains ceiling-capped. The full financial picture including deductions and net pay is laid out below.`,
  25000: `At the ${salary.grossFormatted} monthly level, you are among Singapore's top few percent of earners. This page provides the exact post-tax, post-CPF income calculation for your compensation level.`,
  30000: `Apex-level compensation of ${salary.grossFormatted} per month in Singapore still benefits from remarkably low effective tax rates by global standards. See the precise numbers for your income tier below.`,
};

const tableDescTexts: Record<number, string> = {
  3000: `As you age in Singapore, CPF rates step down, meaning more cash reaches your pocket. For someone on ${salary.grossFormatted}, here is the take-home difference at each life stage.`,
  4000: `Singapore's CPF system reduces contribution rates as workers age, progressively increasing cash income. The table below shows what ${salary.grossFormatted} yields at each bracket (Citizen, no bonus).`,
  5000: `At ${salary.grossFormatted} gross, CPF deductions are substantial for younger workers but decrease significantly after age 55. The following comparison illustrates this effect on net pay.`,
  6000: `CPF rates in Singapore drop in stages after age 55, shifting more of your ${salary.grossFormatted} salary from mandatory savings to liquid income. Each age bracket produces different take-home figures.`,
  7000: `The interaction between age-based CPF rates and the wage ceiling makes the ${salary.grossFormatted} salary level particularly interesting. Below is the variation in net pay across Singapore's age brackets.`,
  8000: `With ${salary.grossFormatted} above the CPF ceiling, the age-based rate reductions primarily affect the ceiling-capped portion. See how each age bracket changes your monthly net income.`,
  10000: `For ${salary.grossFormatted} earners, CPF is already ceiling-capped for younger workers. The age-bracket table below shows how the reducing rates on the capped amount affect your actual income over time.`,
  12000: `Singapore's graduated CPF reduction with age has a defined impact on ${salary.grossFormatted} salaries. Since CPF is ceiling-capped, the changes are modest but still meaningful for planning.`,
  15000: `At ${salary.grossFormatted}, the CPF ceiling means age-related rate changes produce consistent and predictable shifts in take-home pay. Review the bracket-by-bracket comparison below.`,
  20000: `Even at ${salary.grossFormatted}, the CPF age bracket system creates variation in monthly take-home. The ceiling-capped structure means these differences are quantifiable and steady across age groups.`,
  25000: `For executives earning ${salary.grossFormatted}, CPF's age-linked rates affect only the ceiling-capped portion. The table below shows the resulting take-home at each age stage.`,
  30000: `At the ${salary.grossFormatted} compensation level, CPF's age-based system produces predictable shifts in take-home as the ceiling-capped contributions step down progressively with age.`,
};

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": `${salary.grossFormatted} Salary`, "item": `${siteUrl}/salary-${salary.slug}/` },
  ],
};

// Schema.org FAQPage - use dynamically generated FAQs
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": content.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} canonical={`${siteUrl}/salary-${salary.slug}/`}>

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Breadcrumb Navigation -->
  <nav aria-label="Breadcrumb" class="mb-8">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li class="text-gray-300">/</li>
      <li class="text-gray-900 font-medium">{salary.grossFormatted} Salary</li>
    </ol>
  </nav>

  <!-- Trust badge -->
  <div class="flex flex-wrap items-center gap-3 mb-6 text-xs text-gray-500">
    <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2.5 py-1 font-medium text-gray-900">
      <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
      </svg>
      Updated for 2026
    </span>
    <span>
      By <a href="/about/" class="font-medium text-gray-700 hover:text-primary">Mottalib Radif, MBA INSEAD</a>
    </span>
  </div>

  <!-- Page Header -->
  <header class="mb-10">
    <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-3 leading-tight">
      {salary.grossFormatted} Salary in Singapore <span class="text-primary">2026</span>
    </h1>
    <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">
      {introTexts[salary.gross] || `How much take-home pay do you get from a ${salary.grossFormatted} monthly salary in Singapore? Here is the full breakdown including CPF contributions and income tax.`}
    </p>
  </header>

  <!-- Stat Cards -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
    <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 text-center">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Monthly Gross</p>
      <p class="text-3xl font-black text-gray-900">{salary.grossFormatted}</p>
      <p class="text-xs text-gray-400 mt-1">{formatSGD(salary.gross * 12)} per year</p>
    </div>
    <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 text-center">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Employee CPF</p>
      <p class="text-3xl font-black text-orange-600">{formatSGD(mainResult.monthlyEmployeeCPF)}</p>
      <p class="text-xs text-gray-400 mt-1">{mainResult.cpfRate ? `${mainResult.cpfRate.employee}% of capped wage` : 'N/A'}</p>
    </div>
    <div class="bg-primary rounded-2xl shadow-md p-6 text-center text-white">
      <p class="text-sm font-medium text-red-100 uppercase tracking-wider mb-1">Monthly Take-Home</p>
      <p class="text-3xl font-black">{formatSGD(mainResult.monthlyTakeHome)}</p>
      <p class="text-xs text-red-200 mt-1">After CPF & tax (age ≤55)</p>
    </div>
  </section>

  <!-- Band Context: Salary Position -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Understanding a {salary.grossFormatted} Salary in Singapore</h2>
    <p>{content.bandContext}</p>
  </article>

  <!-- Career Description -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Who Earns {salary.grossFormatted} in Singapore?</h2>
    <p>{content.careerDescription}</p>
  </article>

  <!-- Age Bracket Comparison Table -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">
      {salary.grossFormatted} Net Pay by Age Bracket
    </h2>
    <p class="text-gray-600 mb-6">
      {tableDescTexts[salary.gross] || `CPF contribution rates decrease with age in Singapore. Here is how your take-home pay changes at different age brackets on a ${salary.grossFormatted} monthly salary (Singapore Citizen, no bonus).`}
    </p>
    <div class="overflow-x-auto">
      <table class="w-full bg-white rounded-xl shadow-md border border-gray-100 text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-700">Age Bracket</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">CPF Rate</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Employee CPF</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Employer CPF</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Income Tax</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-900">Take-Home</th>
          </tr>
        </thead>
        <tbody>
          {ageBracketRows.map((row, i) => (
            <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
              <td class="px-4 py-3 font-medium text-gray-900">{row.label}</td>
              <td class="px-4 py-3 text-right text-gray-600">{row.cpfEmployeeRate}</td>
              <td class="px-4 py-3 text-right text-orange-600">{row.cpfEmployee}</td>
              <td class="px-4 py-3 text-right text-blue-600">{row.cpfEmployer}</td>
              <td class="px-4 py-3 text-right text-red-600">{row.monthlyTax}</td>
              <td class="px-4 py-3 text-right font-bold text-green-700">{row.net}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- CPF Deep Dive -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">CPF Breakdown and Projections for {salary.grossFormatted} Salary</h2>
    <p>{content.cpfDeepDive}</p>
  </article>

  <!-- Budget Breakdown -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Living in Singapore on {salary.grossFormatted} per Month</h2>
    <p>{content.budgetBreakdown}</p>
  </article>

  <!-- Raise Simulation -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Salary Raise Impact from {salary.grossFormatted}</h2>
    <p>{content.raiseSimulation}</p>
  </article>

  <!-- Tax Optimisation Tips -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Tax Optimisation at {salary.grossFormatted} Income</h2>
    <p>{content.taxTips}</p>
  </article>

  <!-- Salary Comparisons -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">How {salary.grossFormatted} Compares to Other Salary Levels</h2>
    <p>{content.comparisons}</p>
  </article>

  <!-- Financial Milestones -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Financial Milestones on a {salary.grossFormatted} Salary</h2>
    <p>{content.financialMilestones}</p>
  </article>

  <!-- Singapore Policy Context -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Singapore Policies Relevant to {salary.grossFormatted} Earners</h2>
    <p>{content.singaporeContext}</p>
  </article>

  <!-- Calculator -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">
      Personalise Your {salary.grossFormatted} Salary Calculation
    </h2>
    <p class="text-gray-600 mb-6">
      The figures above assume a Singapore Citizen aged 55 and below with no bonus. Use the interactive tool below to adjust for your specific age, PR status, and annual bonus to see your personalised take-home amount on {salary.grossFormatted}.
    </p>
    <SalaryCalculator client:idle />
  </section>

  <!-- FAQ Section (6 dynamically generated FAQs) -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">
      Frequently Asked Questions - {salary.grossFormatted} Salary
    </h2>
    <div class="space-y-4 max-w-3xl">
      {content.faqs.map((faq) => (
        <details class="group bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-4 text-gray-600 leading-relaxed">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- Cross-links: Other Salary Pages -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Explore Other Salary Levels</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {SALARY_LEVELS.filter((s) => s.slug !== salary.slug).map((s) => (
        <a
          href={`/salary-${s.slug}/`}
          class="block bg-white rounded-lg border border-gray-200 px-4 py-3 text-center font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors"
        >
          {s.grossFormatted}
        </a>
      ))}
    </div>
  </section>

  <!-- Cross-links: CPF Age Bracket Pages -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">CPF Rates by Age Bracket</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {AGE_BRACKETS.map((ab) => (
        <a
          href={`/cpf-${ab.slug}/`}
          class="block bg-white rounded-lg border border-gray-200 px-4 py-3 text-center font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors"
        >
          {ab.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800 mb-8">
    <p class="font-semibold mb-1">Disclaimer</p>
    <p>
      This calculator provides estimates based on CPF contribution rates and IRAS income tax brackets for
      Year of Assessment 2026. Actual amounts may vary depending on individual circumstances, additional
      reliefs, bonuses, and policy changes. For official figures, consult the
      <a href="https://www.cpf.gov.sg" target="_blank" rel="noopener noreferrer" class="underline hover:text-amber-900">CPF Board</a>
      and <a href="https://www.iras.gov.sg" target="_blank" rel="noopener noreferrer" class="underline hover:text-amber-900">IRAS</a>.
      This site is not affiliated with any government agency.
    </p>
  </aside>

  <!-- Sources & References -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Sources and References</h2>
    <p class="text-sm text-gray-600 mb-4">
      The calculations on this page are based on publicly available data from the following official Singapore government sources. We recommend consulting these authorities directly for the most up-to-date information.
    </p>
    <ul class="space-y-3 max-w-3xl">
      <li class="flex items-start gap-3 bg-white rounded-lg border border-gray-200 px-4 py-3">
        <span class="text-primary font-bold mt-0.5">1.</span>
        <div>
          <a href="https://www.cpf.gov.sg" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-900 hover:text-primary transition-colors">
            Central Provident Fund Board (CPF Board)
          </a>
          <p class="text-sm text-gray-500 mt-0.5">CPF contribution rates, wage ceilings, allocation ratios, and mandatory savings policies.</p>
          <span class="text-xs text-gray-400">cpf.gov.sg</span>
        </div>
      </li>
      <li class="flex items-start gap-3 bg-white rounded-lg border border-gray-200 px-4 py-3">
        <span class="text-primary font-bold mt-0.5">2.</span>
        <div>
          <a href="https://www.iras.gov.sg" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-900 hover:text-primary transition-colors">
            Inland Revenue Authority of Singapore (IRAS)
          </a>
          <p class="text-sm text-gray-500 mt-0.5">Income tax brackets, personal reliefs, tax residency rules, and Year of Assessment guidelines.</p>
          <span class="text-xs text-gray-400">iras.gov.sg</span>
        </div>
      </li>
      <li class="flex items-start gap-3 bg-white rounded-lg border border-gray-200 px-4 py-3">
        <span class="text-primary font-bold mt-0.5">3.</span>
        <div>
          <a href="https://www.mom.gov.sg" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-900 hover:text-primary transition-colors">
            Ministry of Manpower (MOM)
          </a>
          <p class="text-sm text-gray-500 mt-0.5">Employment regulations, work pass policies, salary benchmarks, and labour market statistics.</p>
          <span class="text-xs text-gray-400">mom.gov.sg</span>
        </div>
      </li>
      <li class="flex items-start gap-3 bg-white rounded-lg border border-gray-200 px-4 py-3">
        <span class="text-primary font-bold mt-0.5">4.</span>
        <div>
          <a href="https://www.singstat.gov.sg" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-900 hover:text-primary transition-colors">
            Department of Statistics Singapore (DOS)
          </a>
          <p class="text-sm text-gray-500 mt-0.5">Median income data, household expenditure surveys, wage percentile distributions, and economic indicators.</p>
          <span class="text-xs text-gray-400">singstat.gov.sg</span>
        </div>
      </li>
    </ul>
  </section>

</Layout>
