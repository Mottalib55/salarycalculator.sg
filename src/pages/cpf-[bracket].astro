---
import Layout from '../layouts/Layout.astro';
import SalaryCalculator from '../components/SalaryCalculator';
import { AGE_BRACKETS, type AgeBracketEntry } from '../lib/age-brackets-data';
import { SALARY_LEVELS } from '../lib/salaries-data';
import { calculateSalary } from '../lib/engine';
import type { ResidencyType } from '../lib/cpf-rates-2026';
import '../styles/global.css';

export function getStaticPaths() {
  return AGE_BRACKETS.map((ab) => ({
    params: { bracket: ab.slug },
    props: { bracket: ab },
  }));
}

interface Props {
  bracket: AgeBracketEntry;
}

const { bracket } = Astro.props;
const siteUrl = 'https://salarycalculator.sg';

// Representative age for calculations
function getRepresentativeAge(slug: string): number {
  switch (slug) {
    case 'below-55': return 30;
    case '55-60': return 58;
    case '60-65': return 63;
    case '65-70': return 68;
    case 'above-70': return 73;
    case 'foreigner-ep': return 30;
    default: return 30;
  }
}

const repAge = getRepresentativeAge(bracket.slug);
const residencyType: ResidencyType = bracket.slug === 'foreigner-ep' ? 'foreigner' : 'citizen';

// Salary comparison table for this age bracket
const salaryRows = SALARY_LEVELS.map((s) => {
  const result = calculateSalary({
    monthlyGross: s.gross,
    age: repAge,
    residencyType,
    annualBonus: 0,
  });
  return {
    grossFormatted: s.grossFormatted,
    slug: s.slug,
    cpfEmployee: `S$${result.monthlyEmployeeCPF.toLocaleString('en-SG')}`,
    cpfEmployer: `S$${result.cpf.employerContribution.toLocaleString('en-SG')}`,
    monthlyTax: `S$${result.monthlyTax.toLocaleString('en-SG')}`,
    takeHome: `S$${result.monthlyTakeHome.toLocaleString('en-SG')}`,
    annualNet: `S$${result.annualNetIncome.toLocaleString('en-SG')}`,
  };
});

function formatSGD(n: number): string {
  return `S$${n.toLocaleString('en-SG')}`;
}

const pageTitle = `CPF Rates for ${bracket.label} - Singapore Salary Impact 2026`;
const pageDescription = `CPF contribution rates for ${bracket.label} in Singapore: ${bracket.cpfEmployeeRate}% employee, ${bracket.cpfEmployerRate}% employer. See the impact on take-home pay across salary levels for 2026.`;

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": `CPF: ${bracket.label}`, "item": `${siteUrl}/cpf-${bracket.slug}/` },
  ],
};

// Schema.org FAQPage
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": bracket.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} canonical={`${siteUrl}/cpf-${bracket.slug}/`}>

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Breadcrumb Navigation -->
  <nav aria-label="Breadcrumb" class="mb-8">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li class="text-gray-300">/</li>
      <li class="text-gray-900 font-medium">CPF: {bracket.label}</li>
    </ol>
  </nav>

  <!-- Trust badge -->
  <div class="flex flex-wrap items-center gap-3 mb-6 text-xs text-gray-500">
    <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2.5 py-1 font-medium text-gray-900">
      <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
      </svg>
      Updated for 2026
    </span>
    <span>
      By <a href="/about/" class="font-medium text-gray-700 hover:text-primary">Mottalib Radif, MBA INSEAD</a>
    </span>
  </div>

  <!-- Page Header -->
  <header class="mb-10">
    <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-3 leading-tight">
      CPF Rates for {bracket.label} <span class="text-primary">2026</span>
    </h1>
    <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">
      {bracket.ageRange} - Employee contributes {bracket.cpfEmployeeRate}%, employer contributes {bracket.cpfEmployerRate}%.
      See how this affects take-home pay across different salary levels.
    </p>
  </header>

  <!-- Rate Cards -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
    <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 text-center">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Employee Rate</p>
      <p class="text-3xl font-black text-orange-600">{bracket.cpfEmployeeRate}%</p>
      <p class="text-xs text-gray-400 mt-1">Deducted from salary</p>
    </div>
    <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 text-center">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Employer Rate</p>
      <p class="text-3xl font-black text-blue-600">{bracket.cpfEmployerRate}%</p>
      <p class="text-xs text-gray-400 mt-1">Additional contribution</p>
    </div>
    <div class="bg-primary rounded-2xl shadow-md p-6 text-center text-white">
      <p class="text-sm font-medium text-red-100 uppercase tracking-wider mb-1">Total CPF Rate</p>
      <p class="text-3xl font-black">{bracket.cpfEmployeeRate + bracket.cpfEmployerRate}%</p>
      <p class="text-xs text-red-200 mt-1">Combined contribution</p>
    </div>
  </section>

  <!-- Description -->
  <article class="prose prose-lg max-w-4xl text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-gray-900">Understanding CPF for {bracket.label}</h2>
    <p>{bracket.description}</p>
  </article>

  <!-- Salary Comparison Table -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">
      Take-Home Pay by Salary Level - {bracket.label}
    </h2>
    <p class="text-gray-600 mb-6">
      How much take-home pay do you get at different salary levels with the {bracket.label} CPF rates?
      {bracket.slug === 'foreigner-ep'
        ? 'No CPF applies - only income tax is deducted.'
        : `Employee CPF is ${bracket.cpfEmployeeRate}%, employer CPF is ${bracket.cpfEmployerRate}%.`
      }
    </p>
    <div class="overflow-x-auto">
      <table class="w-full bg-white rounded-xl shadow-md border border-gray-100 text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-700">Gross Salary</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Employee CPF</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Employer CPF</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Monthly Tax</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-900">Take-Home</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Annual Net</th>
          </tr>
        </thead>
        <tbody>
          {salaryRows.map((row, i) => (
            <tr class={`border-b border-gray-100 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
              <td class="px-4 py-3 font-medium">
                <a href={`/salary-${row.slug}/`} class="text-primary hover:text-primary-dark transition-colors">
                  {row.grossFormatted}
                </a>
              </td>
              <td class="px-4 py-3 text-right text-orange-600">{row.cpfEmployee}</td>
              <td class="px-4 py-3 text-right text-blue-600">{row.cpfEmployer}</td>
              <td class="px-4 py-3 text-right text-red-600">{row.monthlyTax}</td>
              <td class="px-4 py-3 text-right font-bold text-green-700">{row.takeHome}</td>
              <td class="px-4 py-3 text-right text-gray-600">{row.annualNet}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Calculator -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">
      Calculate Your Exact Take-Home Pay
    </h2>
    <p class="text-gray-600 mb-6">
      Use the interactive calculator below to fine-tune your salary, age, and residency status for a precise breakdown.
    </p>
    <SalaryCalculator client:idle />
  </section>

  <!-- FAQ Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">
      Frequently Asked Questions - CPF for {bracket.label}
    </h2>
    <div class="space-y-4 max-w-3xl">
      {bracket.faqs.map((faq) => (
        <details class="group bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-4 text-gray-600 leading-relaxed">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- Cross-links: Other Age Brackets -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Other CPF Age Brackets</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {AGE_BRACKETS.filter((ab) => ab.slug !== bracket.slug).map((ab) => (
        <a
          href={`/cpf-${ab.slug}/`}
          class="block bg-white rounded-lg border border-gray-200 px-4 py-3 text-center font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors"
        >
          <span class="block text-sm">{ab.label}</span>
          <span class="block text-xs text-gray-400 mt-0.5">{ab.cpfEmployeeRate}% + {ab.cpfEmployerRate}%</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Cross-links: Salary Pages -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Explore Salary Levels</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {SALARY_LEVELS.map((s) => (
        <a
          href={`/salary-${s.slug}/`}
          class="block bg-white rounded-lg border border-gray-200 px-4 py-3 text-center font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors"
        >
          {s.grossFormatted}
        </a>
      ))}
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800 mb-8">
    <p class="font-semibold mb-1">Disclaimer</p>
    <p>
      This page provides estimates based on CPF contribution rates and IRAS income tax brackets for
      Year of Assessment 2026. Actual amounts may vary depending on individual circumstances, additional
      reliefs, bonuses, and policy changes. For official figures, consult the
      <a href="https://www.cpf.gov.sg" target="_blank" rel="noopener noreferrer" class="underline hover:text-amber-900">CPF Board</a>
      and <a href="https://www.iras.gov.sg" target="_blank" rel="noopener noreferrer" class="underline hover:text-amber-900">IRAS</a>.
      This site is not affiliated with any government agency.
    </p>
  </aside>

</Layout>
